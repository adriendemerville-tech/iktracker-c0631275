# Cache headers for Netlify/Cloudflare Pages
# Optimized for maximum performance

# Default headers for all pages
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin

# Hashed assets (JS, CSS) - immutable, maximum cache
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept-Encoding

# Images - immutable with encoding variation
*.webp
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept-Encoding

*.png
  Cache-Control: public, max-age=31536000, immutable

*.jpg
  Cache-Control: public, max-age=31536000, immutable

*.svg
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept-Encoding

# Fonts - immutable long cache
*.woff2
  Cache-Control: public, max-age=31536000, immutable

*.woff
  Cache-Control: public, max-age=31536000, immutable

# Compressed assets
*.js.gz
  Cache-Control: public, max-age=31536000, immutable
  Content-Encoding: gzip
  Content-Type: application/javascript

*.js.br
  Cache-Control: public, max-age=31536000, immutable
  Content-Encoding: br
  Content-Type: application/javascript

*.css.gz
  Cache-Control: public, max-age=31536000, immutable
  Content-Encoding: gzip
  Content-Type: text/css

*.css.br
  Cache-Control: public, max-age=31536000, immutable
  Content-Encoding: br
  Content-Type: text/css

# PWA files - must revalidate
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

/manifest.webmanifest
  Cache-Control: public, max-age=86400

# HTML - stale-while-revalidate for faster perceived load
/*.html
  Cache-Control: public, max-age=0, must-revalidate, stale-while-revalidate=86400

/
  Cache-Control: public, max-age=0, must-revalidate, stale-while-revalidate=86400

# Robots and sitemap
/robots.txt
  Cache-Control: public, max-age=86400

/sitemap.xml
  Cache-Control: public, max-age=86400
